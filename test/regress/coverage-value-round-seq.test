; Coverage for value.cc round_to_commodity_precision for sequence,
; and SEQUENCE -> STRING conversion introduced for the ==~ operator.

2024/01/15 Test
    Expenses:Food    $50.123
    Assets:Checking

; Test: rounded(to_sequence(amount)) creates a sequence, rounds each
; element, then renders the sequence via the SEQUENCE -> STRING cast.
test reg --format '%(rounded(to_sequence(amount)))\n' Expenses
